# ──────────────────────────────────────────────────────────
# Supplement Care API — Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# ── Required ──
OPENAI_API_KEY=your_openai_api_key_here

# ── Optional ──
# If you have an NCBI API key, set it here to raise the rate limit.
NCBI_API_KEY=optional_ncbi_api_key_here

# If you have an MFDS API key, set it here for regulatory queries.
MFDS_API_KEY=optional_mfds_api_key_here
